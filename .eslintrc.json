{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": { "ecmaVersion": "latest" },
  "globals": {
    "selectPerson": "writable",
    "selectRel": "writable",
    "openPersonSearch": "writable",
    "heroSearchSubmit": "writable",
    "castVote": "writable",
    "demoVote": "writable",
    "closeModal": "writable",
    "updateCharCounter": "writable"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["warn", "single"]
  }
}
